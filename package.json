{
  "name": "mcp-realbrowser",
  "version": "1.0.0",
  "description": "MCP server that connects to your real Chrome browser — AI sees what you see, clicks what you click",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-realbrowser": "./dist/index.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "browser",
    "chrome",
    "cdp",
    "playwright",
    "claude",
    "claude-code",
    "ai-agent",
    "browser-automation",
    "real-browser"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "playwright": "^1.52.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
